---
import type { SectionItem } from '../../data/sections';

interface Props {
  item: SectionItem;
}
const { item } = Astro.props;

// Render as <a> when the item has a link, otherwise a plain <article>.
// Capitalised so Astro treats it as a component, not a literal <tag>.
const Tag = item.href ? 'a' : 'article';

// An external link is any href that isn't a same-origin path.
// Downloads (/files/cv.pdf) stay in-tab; github.com opens a new one.
const isExternal = !!item.href && /^https?:\/\//.test(item.href);
const opensNewTab = isExternal && !item.download;

// ↓ download · ↗ external · nothing if not linked
const marker = item.download ? '↓' : isExternal ? '↗' : '';
---

<Tag
  class:list={[
    'block rounded border bg-bg px-[22px] py-5 no-underline',
    item.href
      ? 'border-line-soft transition-all hover:border-accent hover:bg-panel cursor-pointer'
      : 'border-line',
  ]}
  href={item.href}
  download={item.download}
  target={opensNewTab ? '_blank' : undefined}
  rel={opensNewTab ? 'noopener noreferrer' : undefined}
>
  <div
    class="flex justify-between gap-4 text-[15px]
           max-[900px]:flex-col max-[900px]:gap-1"
  >
    {/* Accent title = clickable. The web's native signal for a link. */}
    <span class:list={['break-words', item.href ? 'text-accent' : 'text-txt-bright']}>
      {item.title}
    </span>
    <span class="whitespace-nowrap text-xs text-txt-faint">
      {item.meta}{marker && <span class="text-accent">{' ' + marker}</span>}
    </span>
  </div>
  {item.role && (
  <p class="mt-1 text-[12.5px] leading-[1.5] text-txt-body">{item.role}</p>
)}
<p class="mt-2 text-[12.5px] leading-[1.7] text-txt-dim">{item.desc}</p>

{item.bullets && (
  <ul class="mt-3 flex list-none flex-col gap-2 p-0">
    {item.bullets.map((b) => (
      <li class="relative pl-4 text-[12.5px] leading-[1.7] text-txt-dim before:absolute before:left-0 before:text-txt-faint before:content-['·']">
        {b}
      </li>
    ))}
  </ul>
)}
{item.tags && (
  <ul class="mt-4 flex list-none flex-wrap gap-2 p-0">
    {item.tags.map((t) => (
      <li class="rounded-full border border-line-soft px-2.5 py-1 text-[11px] text-txt-faint">
        {t}
      </li>
    ))}
  </ul>
)}
</Tag>