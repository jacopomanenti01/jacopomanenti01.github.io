---
interface Props {
  path: string;  
  details: string;  
}
const { path, details } = Astro.props;
---

<div
  class="mb-7 flex justify-between gap-4 text-xs tracking-[0.14em] text-txt-faint
         max-[900px]:mb-4 max-[900px]:flex-col max-[900px]:gap-1"
>
  <span>
    <a class="text-accent no-underline hover:underline" href="#" data-home>~/Jacopo</a><span>/{path}</span>
  </span>
  <span>{details}</span>
</div>