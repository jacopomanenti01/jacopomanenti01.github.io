---
import Card from './Card.astro';
import PaneHead from './PaneHead.astro';
import type { Section } from '../../data/sections';

interface Props {
  section: Section;
}

const { section } = Astro.props;
---

<div class="pane" data-pane={section.id} hidden>
  <PaneHead path={section.id} details={section.details} />

  <div class="flex flex-col gap-[14px]">
    {section.items.map((it) => <Card item={it} />)}

    {
      section.footnote &&
        (section.footnoteHref ? (
          <a
            class="px-[2px] py-[6px] text-xs text-txt-faint no-underline transition-all hover:text-accent"
            href={section.footnoteHref}
            target="_blank"
            rel="noopener noreferrer"
          >
            {section.footnote}
          </a>
        ) : (
          <div class="px-[2px] py-[6px] text-xs text-txt-faint">
            {section.footnote}
          </div>
        ))
    }

  </div>
</div>