---
import Lightbox from '../components/Lightbox.astro';
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Jacopo Manenti — AI Engineer & Researcher, Finance',
  description = 'AI Engineer & Researcher in Finance. LLM systems in production at the European Central Bank — RAG, data pipelines, ML research for markets.',
} = Astro.props;

const person = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Jacopo Manenti",
  jobTitle: "AI Engineer & Researcher",
  worksFor: { "@type": "Organization", name: "European Central Bank" },
  url: "https://jacopomanenti01.github.io",
  image: "https://jacopomanenti01.github.io/portrait.jpeg",
  sameAs: [
    "https://github.com/jacopomanenti01",
    "https://www.linkedin.com/in/jacopo-manenti-7885651a7/",
  ],
  alumniOf: [
    { "@type": "CollegeOrUniversity", name: "EIT Digital Master School" },
    { "@type": "CollegeOrUniversity", name: "Università degli Studi di Trento" },
    { "@type": "CollegeOrUniversity", name: "Eötvös Loránd University" },
    { "@type": "CollegeOrUniversity", name: "Università Cattolica del Sacro Cuore" },
  ],
  knowsAbout: ["Retrieval-Augmented Generation", "Machine Learning", "Fintech", 'LLM', 'Agents', 'Data Science'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="google-site-verification" content="MG3WbV5-_TYfUyQLOmXwhiRwbj2qIj4b5IWVrm_lC3s" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    
    <script type="application/ld+json" set:html={JSON.stringify(person)} />

  </head>
  <body class="m-0 min-h-screen bg-bg font-mono text-txt">
    <div class="aura" aria-hidden="true"><span></span></div>
    <slot />
    <Lightbox />
  </body>
</html>