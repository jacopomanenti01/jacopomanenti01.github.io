---
import Lightbox from '../components/Lightbox.astro';
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Jacopo Manenti — AI Engineer & Researcher, European Central Bank',
  description = 'Jacopo Manenti is an Italian AI engineer at the European Central Bank. He builds and deploys cloud-native LLM and ML systems for market operations, and researches ML applications for central banking.',
} = Astro.props;



const person = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Jacopo Manenti",
  givenName: "Jacopo",
  familyName: "Manenti",
  jobTitle: "AI Engineer & Researcher",
  description:
    "Jacopo Manenti is an Italian AI engineer at the European Central Bank. He builds and deploys cloud-native LLM and machine learning systems for market operations, and researches machine learning applications for central banking.",
  url: "https://manenti.dev",
  image: "https://manenti.dev/portrait.jpeg",
  email: "mailto:jacopomanenti01@gmail.com",
  nationality: { "@type": "Country", name: "Italy" },
  worksFor: {
    "@type": "Organization",
    name: "European Central Bank",
    url: "https://www.ecb.europa.eu",
  },
  workLocation: {
    "@type": "Place",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Frankfurt am Main",
      addressCountry: "DE",
    },
  },
  sameAs: [
    "https://github.com/jacopomanenti01",
    "https://www.linkedin.com/in/jacopo-manenti-7885651a7/",
  ],
  alumniOf: [
    {
      "@type": "CollegeOrUniversity",
      name: "EIT Digital Master School",
      url: "https://masterschool.eitdigital.eu",
    },
    {
      "@type": "CollegeOrUniversity",
      name: "Università degli Studi di Trento",
      url: "https://www.unitn.it",
    },
    {
      "@type": "CollegeOrUniversity",
      name: "Eötvös Loránd University",
      url: "https://www.elte.hu",
    },
    {
      "@type": "CollegeOrUniversity",
      name: "Università Cattolica del Sacro Cuore",
      url: "https://www.unicatt.it",
    },
  ],
  knowsAbout: [
    "Large Language Models",
    "Retrieval-Augmented Generation",
    "Machine Learning",
    "Quantitative Finance",
    "Central Banking",
    "Data Engineering",
    "Fintech", 
    'Agents', 
    'Data Science'
  ],
};

const site = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Jacopo Manenti",
  url: "https://manenti.dev",
};

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="google-site-verification" content="MG3WbV5-_TYfUyQLOmXwhiRwbj2qIj4b5IWVrm_lC3s" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
    
    <script type="application/ld+json" set:html={JSON.stringify(person)} />
    <script type="application/ld+json" set:html={JSON.stringify(site)} />

  </head>
  <body class="m-0 min-h-screen bg-bg font-mono text-txt">
    <div class="aura" aria-hidden="true"><span></span></div>
    <slot />
    <Lightbox />
  </body>
</html>